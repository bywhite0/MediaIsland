<ci:ComponentBase x:Class="MediaIsland.Components.LyricsComponentSettings"
                  x:TypeArguments="local:LyricsComponentConfig"
                  xmlns:ci="http://classisland.tech/schemas/xaml/core"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="clr-namespace:MediaIsland.Components"
                  mc:Ignorable="d"
                  d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:LyricsComponentSettings}}">
        <StackPanel Style="{StaticResource SettingsPageStackPanelStyle}">
            <ci:SettingsCard IconGlyph="HideOutline"
                             Header="无内容时隐藏组件"
                             Description="没有媒体会话、未找到歌词或状态文本关闭时隐藏本组件。"
                             IsOn="{Binding Settings.IsHideWhenEmpty, Mode=TwoWay}" />
            <ci:SettingsCard IconGlyph="InfoCircleOutline"
                             Header="显示状态文本"
                             Description="显示等待媒体信息、查找歌词和未找到歌词等调试状态。"
                             IsOn="{Binding Settings.IsShowStatusText, Mode=TwoWay}" />
            <Label HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}">
                Lyrics powered by MediaIsland
            </Label>
        </StackPanel>
    </ScrollViewer>
</ci:ComponentBase>
