<ci:ComponentBase x:Class="MediaIsland.Components.LyricsComponentSettings"
                  x:TypeArguments="local:LyricsComponentConfig"
                  xmlns:ci="http://classisland.tech/schemas/xaml/core"
                  xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:controls="using:FluentAvalonia.UI.Controls"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="clr-namespace:MediaIsland.Components"
                  mc:Ignorable="d"
                  d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:LyricsComponentSettings}}">
        <StackPanel>
            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xE817;}"
                                       Header="无内容时隐藏组件"
                                       Description="没有媒体会话、未找到歌词或状态文本关闭时隐藏本组件。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsHideWhenEmpty, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xF07B;}"
                                       Header="显示状态文本"
                                       Description="显示等待媒体信息、查找歌词和未找到歌词等状态。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsShowStatusText, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xEBC9;}"
                                       Header="显示音符图标"
                                       Description="在歌词文本左侧显示音符图标。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsShowNoteIcon, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xE0ED;}"
                                       Header="固定歌词宽度"
                                       Description="按当前歌曲最长歌词行的宽度固定歌词区，避免一首歌内组件宽度随换行连续变化。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsFixedWidthToMaxLineEnabled, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xE093;}"
                                       Header="左右间距"
                                       Description="启用后，对应侧的元素边界将收缩至适合圆角。">
                <controls:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="(左"
                               Foreground="Gray" />
                        <ToggleButton Margin="0,0,5,0"
                                      IsChecked="{Binding Settings.IsLeftNegativeMargin, Mode=TwoWay}" />
                        <Label Content="♪ --"
                               Foreground="Gray" />
                        <ToggleButton Margin="5,0,0,0"
                                      IsChecked="{Binding Settings.IsRightNegativeMargin, Mode=TwoWay}" />
                        <Label Content="右)"
                               Foreground="Gray" />
                    </StackPanel>
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xEC10;}"
                                       Header="显示内容"
                                       Description="选择展示原文、翻译（如有）或音译（如有）。缺失时回退到原文；非原文时不使用逐字高亮。">
                <controls:SettingsExpander.Footer>
                    <ComboBox MinWidth="130"
                              SelectedIndex="{Binding Settings.DisplayPartIndex, Mode=TwoWay}">
                        <ComboBoxItem>原文</ComboBoxItem>
                        <ComboBoxItem>翻译（如有）</ComboBoxItem>
                        <ComboBoxItem>音译（如有）</ComboBoxItem>
                    </ComboBox>
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xE8CB;}"
                                       Header="渲染帧率"
                                       Description="控制逐字歌词进度的刷新频率。60 FPS 更平滑，但会占用更多资源。">
                <controls:SettingsExpander.Footer>
                    <ComboBox MinWidth="110"
                              SelectedIndex="{Binding Settings.RenderFrameRateIndex, Mode=TwoWay}">
                        <ComboBoxItem>30 FPS</ComboBoxItem>
                        <ComboBoxItem>60 FPS</ComboBoxItem>
                    </ComboBox>
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <Label HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}">
                Powered by MediaIsland
            </Label>
            <Label HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}">
                Lyrics powered by LttF.
            </Label>
        </StackPanel>
    </ScrollViewer>
</ci:ComponentBase>
