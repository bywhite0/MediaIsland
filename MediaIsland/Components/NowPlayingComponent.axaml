<ci:ComponentBase x:Class="MediaIsland.Components.NowPlayingComponent"
                  x:TypeArguments="local:NowPlayingComponentConfig"
                  xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:ci="http://classisland.tech/schemas/xaml/core"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:converters="using:MediaIsland.Converters"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:local="clr-namespace:MediaIsland.Components"
                  mc:Ignorable="d"
                  d:DesignHeight="450" d:DesignWidth="800"
                  Loaded="NowPlayingComponent_OnLoaded"
                  Unloaded="NowPlayingComponent_OnUnloaded">
    <ci:ComponentBase.Resources>
        <converters:DoubleToCornerRadiusConverter x:Key="DoubleToCornerRadiusConverter" />
    </ci:ComponentBase.Resources>
    <Grid x:Name="MediaGrid"
          Margin="0"
          HorizontalAlignment="Center"
          VerticalAlignment="Stretch"
          DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:NowPlayingComponent}}">
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto"
              Margin="0"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <StackPanel Name="StatusStackPanel" Grid.Column="0" Margin="0" Orientation="Horizontal" IsVisible="{Binding Settings.IsShowPlaybackStatus}">
                <ci:FluentIcon x:Name="StatusIcon" Glyph="&#xEDB8;" VerticalAlignment="Center" Margin="0 0 4 0" />
            </StackPanel>
            <StackPanel Name="CoverStackPanel" Grid.Column="1" Margin="0" Orientation="Horizontal" IsVisible="{Binding Settings.IsShowAlbumArt}">
                <Grid Name="CoverGrid" Margin="0" ClipToBounds="True" Width="28" Height="28">
                    <ci:FluentIcon Name="CoverPlaceholder" Glyph="&#xEBC9;" VerticalAlignment="Center" Margin="0" IsVisible="false" FontSize="22" />
                    <Border CornerRadius="3" ClipToBounds="True">
                        <Image x:Name="AlbumArt" Stretch="UniformToFill" />
                    </Border>
                </Grid>
            </StackPanel>
            <StackPanel Name="InfoStackPanel" Grid.Column="2" Margin="4 0 0 0" Orientation="Vertical" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="14" Margin="0" d:LayoutOverrides="TopPosition, BottomPosition" />
                <TextBlock x:Name="ArtistText" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="10" Margin="0" />
                <TextBlock x:Name="TimeText" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="10" Margin="0" IsVisible="false"/>
            </StackPanel>
            <StackPanel Name="SourceStackPanel" Grid.Column="3" Margin="4 0 0 0" Orientation="Vertical" VerticalAlignment="Center" IsVisible="{Binding Settings.IsShowSourceArea}">
                <Border Name="SourceIconBorder" HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="{Binding Settings.SourceIconRadius, Converter={StaticResource DoubleToCornerRadiusConverter}}" Margin="0" ClipToBounds="True" Width="22" Height="22" IsVisible="{Binding Settings.IsShowSource}">
                    <Image x:Name="SourceIcon" Stretch="UniformToFill" />
                </Border>
                <TextBlock x:Name="SourceText" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="8" IsVisible="{Binding Settings.IsShowSourceName}"/>
            </StackPanel>
        </Grid>

        <!-- 复用 ClassIsland CountDown/MainWindowLine 的 Canvas + ProgressBar 布局模式 -->
        <Canvas VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                x:Name="ProgressContainer"
                Height="{Binding #ProgressBar.Bounds.Height}"
                IsVisible="False">
            <ProgressBar Maximum="1"
                         Minimum="0"
                         Width="{Binding #ProgressContainer.Bounds.Width, Mode=OneWay}"
                         x:Name="ProgressBar"
                         MinWidth="0"
                         Value="0">
                <ProgressBar.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Value" Duration="0:0:0.05">
                            <DoubleTransition.Easing>
                                <LinearEasing />
                            </DoubleTransition.Easing>
                        </DoubleTransition>
                    </Transitions>
                </ProgressBar.Transitions>
            </ProgressBar>
        </Canvas>
    </Grid>
</ci:ComponentBase>
