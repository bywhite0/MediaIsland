<ci:SettingsPageBase x:Class="MediaIsland.SettingsPages.GeneralSettingsPage"
                     xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:controls="using:FluentAvalonia.UI.Controls"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:local="clr-namespace:MediaIsland.SettingsPages"
                     mc:Ignorable="d"
                     d:DesignHeight="450" d:DesignWidth="800"
                     TextElement.Foreground="{DynamicResource MaterialDesignBody}"
                     Background="{DynamicResource MaterialDesignPaper}"
                     FontFamily="{StaticResource HarmonyOsSans}"
                     TextElement.FontWeight="Regular"
                     TextElement.FontSize="14">
	    <ScrollViewer DataContext="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=local:GeneralSettingsPage}}">
	        <StackPanel Classes="settings-container animated-intro">
	            <ci:IconText Glyph="&#xEBC9;" Text="当前媒体" Margin="0 0 0 8" />
	            <Border Margin="0 0 0 8"
	                    Padding="14"
	                    CornerRadius="4"
	                    Background="{DynamicResource MaterialDesignCardBackground}">
	                <Grid ColumnDefinitions="Auto,*">
	                    <Border Width="64"
	                            Height="64"
	                            CornerRadius="4"
	                            ClipToBounds="True"
	                            Background="{DynamicResource MaterialDesignDivider}">
	                        <Grid>
	                            <Image Source="{Binding CurrentMediaThumbnail}"
	                                   Stretch="UniformToFill"
	                                   IsVisible="{Binding HasCurrentMediaThumbnail}" />
	                            <ci:FluentIcon Glyph="&#xEBC9;"
	                                           FontSize="28"
	                                           HorizontalAlignment="Center"
	                                           VerticalAlignment="Center"
	                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
	                                           IsVisible="{Binding !HasCurrentMediaThumbnail}" />
	                        </Grid>
	                    </Border>
	                    <StackPanel Grid.Column="1" Margin="14 0 0 0" VerticalAlignment="Center">
	                        <TextBlock Text="{Binding CurrentMediaTitle}"
	                                   FontSize="16"
	                                   FontWeight="Medium"
	                                   TextTrimming="CharacterEllipsis" />
	                        <TextBlock Text="{Binding CurrentMediaArtistAlbum}"
	                                   Margin="0 4 0 0"
	                                   Foreground="{DynamicResource MaterialDesignBodyLight}"
	                                   TextTrimming="CharacterEllipsis" />
	                        <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
	                            <ci:FluentIcon Glyph="{Binding CurrentMediaStatusGlyph}"
	                                           FontSize="14"
	                                           Margin="0 0 4 0"
	                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
	                                           VerticalAlignment="Center" />
	                            <TextBlock Text="{Binding CurrentMediaPlaybackStatus}"
	                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
	                                       VerticalAlignment="Center" />
	                            <TextBlock Text=" · "
	                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
	                                       VerticalAlignment="Center" />
	                            <TextBlock Text="{Binding CurrentMediaTimeline}"
	                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
	                                       VerticalAlignment="Center" />
	                        </StackPanel>
	                        <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
	                            <Border Width="16"
	                                    Height="16"
	                                    CornerRadius="3"
	                                    ClipToBounds="True"
	                                    Margin="0 0 4 0"
	                                    ToolTip.Tip="{Binding CurrentMediaSourceIconStatus}">
	                                <Image Source="{Binding CurrentMediaSourceIcon}"
	                                       Stretch="UniformToFill"
	                                       IsVisible="{Binding HasCurrentMediaSourceIcon}" />
	                            </Border>
	                            <TextBlock Text="{Binding CurrentMediaSourceDisplay}"
	                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
	                                       TextTrimming="CharacterEllipsis"
	                                       ToolTip.Tip="{Binding CurrentMediaSourceId}" />
	                        </StackPanel>
	                    </StackPanel>
	                </Grid>
	            </Border>
	            <ci:IconText Glyph="&#xEF27;" Text="通用" Margin="0 0 0 8" />
	            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE561;}"
	                                       Header="播放源列表"
	                                       Description="插件监听的播放源列表，可控制是否显示来自特定播放源的信息，并可自定义显示名称；留空时自动识别。需要重载组件才能生效。">
                            <controls:SettingsExpander.Footer>
                                <ci:FluentIcon Glyph="&#xF19B;"/>
                            </controls:SettingsExpander.Footer>
                    <StackPanel Orientation="Vertical">
                        <DataGrid Margin="12,6,70,6"
                                  IsReadOnly="False"
                                  AutoGenerateColumns="False"
                                  CanUserResizeColumns="False"
                                  CanUserReorderColumns="False"
                                  Height="240"
                                  ItemsSource="{Binding Settings.MediaSourceList, Mode=TwoWay}">
	                            <DataGrid.Columns>
	                                <DataGridTextColumn Header="播放源" Width="Auto" MinWidth="120" MaxWidth="400" Binding="{Binding Source}" />
	                                <DataGridTemplateColumn Header="显示名称" Width="Auto">
	                                    <DataGridTemplateColumn.CellTemplate>
	                                        <DataTemplate>
	                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
	                                        </DataTemplate>
	                                    </DataGridTemplateColumn.CellTemplate>
	                                    <DataGridTemplateColumn.CellEditingTemplate>
	                                        <DataTemplate>
	                                            <TextBox Text="{Binding CustomDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
	                                                     Watermark="留空时自动识别"
	                                                     ToolTip.Tip="自定义播放源名称，留空时自动识别"
	                                                     LostFocus="CustomDisplayNameTextBoxOnLostFocus" />
	                                        </DataTemplate>
	                                    </DataGridTemplateColumn.CellEditingTemplate>
	                                </DataGridTemplateColumn>
	                                <DataGridCheckBoxColumn Header="启用" Width="Auto" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
	                                <DataGridTemplateColumn Header="图标状态" Width="Auto">
	                                    <DataGridTemplateColumn.CellTemplate>
	                                        <DataTemplate>
		                                            <StackPanel Orientation="Horizontal" Spacing="6"
		                                                        ToolTip.Tip="{Binding IconStatus}">
	                                                <Border Width="20" Height="20" CornerRadius="3" ClipToBounds="True">
	                                                    <Image Source="{Binding DisplayIcon}" Stretch="UniformToFill" />
	                                                </Border>
	                                                <TextBlock Text="{Binding IconStatus}" VerticalAlignment="Center" />
	                                            </StackPanel>
	                                        </DataTemplate>
	                                    </DataGridTemplateColumn.CellTemplate>
	                                </DataGridTemplateColumn>
	                                <DataGridTemplateColumn Header="图标操作" Width="Auto">
	                                    <DataGridTemplateColumn.CellTemplate>
	                                        <DataTemplate>
	                                            <StackPanel Orientation="Horizontal" Spacing="2">
	                                                <Button Width="20"
	                                                        Height="20"
	                                                        Margin="0"
	                                                        Padding="4 0"
	                                                        Background="Transparent"
	                                                        BorderBrush="Transparent"
	                                                        Click="ChooseIconButtonOnClick"
	                                                        ToolTip.Tip="自定义图标">
                                                    <ci:FluentIcon Glyph="&#xE9C4;" />
                                                </Button>
	                                                <Button Width="20"
	                                                        Height="20"
	                                                        Margin="0"
	                                                        Padding="4 0"
	                                                        Background="Transparent"
	                                                        BorderBrush="Transparent"
	                                                        Click="ClearIconButtonOnClick"
	                                                        ToolTip.Tip="清除自定义图标">
                                                    <ci:FluentIcon Glyph="&#xE7FF;" />
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="操作" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
	                                            <Button Width="20"
	                                                    Height="20"
	                                                    Margin="0"
	                                                    Padding="4 0"
	                                                    Background="Transparent"
	                                                    BorderBrush="Transparent"
	                                                    Click="DeleteButtonOnClick"
	                                                    ToolTip.Tip="移除播放源">
                                                <ci:FluentIcon Glyph="&#xE61C;" Foreground="Red" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Orientation="Horizontal" Margin="12,0,12,6">
	                            <Button HorizontalAlignment="Left"
	                                    VerticalAlignment="Center"
	                                    Theme="{StaticResource TransparentButton}"
	                                    Classes="accent"
	                                    Click="AddButtonOnClick">
                                <ci:IconText Text="添加当前播放源" Glyph="&#xE00C;" />
                            </Button>
	                            <Button HorizontalAlignment="Left"
	                                    VerticalAlignment="Center"
	                                    Theme="{StaticResource TransparentButton}"
	                                    Classes="accent"
	                                    Click="SaveButtonOnClick">
                                <ci:IconText Text="保存" Glyph="&#xEEB5;" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </controls:SettingsExpander>

            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE2E0;}"
                                       Header="歌词来源"
                                       Description="按列表顺序搜索歌词。可开关来源、逐字歌词偏好，并配置 AMLL TTML API 地址。">
                <controls:SettingsExpander.Footer>
                    <TextBlock Text="{Binding CurrentLyricsSourceDisplay}"
                               FontSize="12" />
                </controls:SettingsExpander.Footer>
                <StackPanel Margin="12,6,12,10" Spacing="8">
                    <ItemsControl ItemsSource="{Binding LyricsSourceItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6"
                                        Margin="0,0,0,6"
                                        CornerRadius="4"
                                        Background="{DynamicResource MaterialDesignCardBackground}">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Medium" />
                                            <TextBlock Text="{Binding Capability}"
                                                       Margin="0,2,0,0"
                                                       FontSize="12" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,8,0" VerticalAlignment="Center">
                                            <TextBlock Text="启用" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <TextBlock Text="逐字" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <ToggleSwitch IsChecked="{Binding UseWordSyncedLyrics, Mode=TwoWay}" />
                                        </StackPanel>
                                        <Button Grid.Column="3"
                                                Content="上移"
                                                Margin="0,0,4,0"
                                                Tag="{Binding}"
                                                Click="MoveLyricsSourceUpOnClick" />
                                        <Button Grid.Column="4"
                                                Content="下移"
                                                Margin="0,0,4,0"
                                                Tag="{Binding}"
                                                Click="MoveLyricsSourceDownOnClick" />
                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="5"
                                                    Orientation="Horizontal"
                                                    Margin="0,8,0,0"
                                                    Spacing="6">
                                            <TextBlock Text="歌词延迟（毫秒）" VerticalAlignment="Center" />
                                            <TextBox Width="88"
                                                     Watermark="0"
                                                     Text="{Binding GlobalOffsetMillisecondsText, Mode=TwoWay}" />
                                            <TextBlock Text="正值提前/负值延后"
                                                       VerticalAlignment="Center"
                                                       FontSize="12" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="AMLL TTML API 地址（留空不使用）" />
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Watermark="https://amll-ttml-api.example.com"
                                 Text="{Binding AmllApiBaseUrl, Mode=TwoWay}" />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Content="测试连接"
                                Click="TestAmllConnectionOnClick" />
                    </Grid>
                    <TextBlock Text="{Binding AmllConnectionStatus}"
                               TextWrapping="Wrap" />
                    <Grid Margin="0,8,0,0" ColumnDefinitions="*,Auto">
                        <TextBlock Text="当前歌词候选"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="刷新"
                                Click="RefreshLyricsCandidatesOnClick" />
                    </Grid>
                    <TextBlock Text="{Binding CurrentLyricsCandidatesStatus}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <DataGrid ItemsSource="{Binding LyricsCandidateItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserResizeColumns="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              DoubleTapped="ApplyLyricsCandidateOnDoubleTapped"
                              Height="220">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="来源" Width="Auto" Binding="{Binding Source}" />
                            <DataGridTextColumn Header="评分" Width="Auto" Binding="{Binding Score}" />
                            <DataGridTextColumn Header="标题" Width="*" Binding="{Binding Title}" />
                            <DataGridTextColumn Header="艺术家" Width="*" Binding="{Binding Artist}" />
                            <DataGridTextColumn Header="专辑" Width="*" Binding="{Binding Album}" />
                            <DataGridTextColumn Header="同步" Width="Auto" Binding="{Binding SyncCapability}" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Text="双击可应用该歌词至组件。"
                               FontWeight="Medium" />
                </StackPanel>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE285;}"
                                       Header="启用逐字歌词"
                                       Description="启用逐字歌词效果，关闭则展示逐行歌词。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsWordLyricsEnabled, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE0BA;}"
                                       Header="显示歌词间奏点动画"
                                       Description="相邻歌词行之间出现超过 4 秒的空档时，以呼吸效果显示三个提示点。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsLyricsInterludeAnimationEnabled, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE61D;}"
                                       Header="启用逐字上浮效果"
                                       Description="逐字歌词推进时，单词内字符依次轻微上浮。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsWordLyricsLiftEnabled, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE29E;}"
                                       Header="启用强调效果"
                                       Description="任意单词持续超过 1 秒时，呈现缩放效果。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsWordLyricsEmphasisEnabled, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE47B;}"
                                       Header="移除封面的 Spotify 水印"
                                       Description="部分版本的 Spotify 桌面版会在传给 SMTC 的封面下方加入其商标，如果你在插件呈现的封面上看到了，可以打开这个开关。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsCutSpotifyTrademarkEnabled, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
            <controls:SettingsExpander IconSource="{ci:LucideIconSource &#xE038;}"
                                       Header="匿名使用情况分析"
                                       Description="本插件使用 Sentry 收集与本插件相关的使用情况与错误信息，以帮助改善本插件，相关信息将被匿名上传。此功能不会收集您的个人信息。">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding Settings.IsTodayEatSentry, Mode=TwoWay}" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</ci:SettingsPageBase>
